generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum ListingStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id         Int      @id @default(autoincrement())
  name       String?
  email      String   @unique
  role       Role     @default(USER)
  magicToken String?
  createdAt  DateTime @default(now())

  @@map("users")
}

model Restaurant {
  id Int @id @default(autoincrement())

  name String

  suburb String

  latitude Float?

  longitude Float?

  image String?

  createdAt DateTime @default(now())

  meals Meal[]

  @@map("restaurants")
}

model Meal {
  id Int @id @default(autoincrement())

  restaurantId Int

  dishName String

  cuisine String?

  price Float

  status ListingStatus @default(PENDING)

  createdAt DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  reports Report[]

  votes Vote[]

  // HOT DEAL RELATION
  hotDeals HotDeal[]

  @@map("meals")
}

model Report {
  id Int @id @default(autoincrement())

  mealId Int

  reason String

  createdAt DateTime @default(now())

  meal Meal @relation(fields: [mealId], references: [id])

  @@map("reports")
}

enum VoteType {
  UP
  DOWN
}

model Vote {
  id Int @id @default(autoincrement())

  mealId Int

  meal Meal @relation(fields: [mealId], references: [id])

  voteType VoteType

  deviceId String?

  ipAddress String?

  createdAt DateTime @default(now())

  @@unique([mealId, deviceId])
  @@map("votes")
}

model HotDeal {
  id Int @id @default(autoincrement())

  mealId Int

  meal Meal @relation(fields: [mealId], references: [id])

  startDateTime DateTime

  endDateTime DateTime

  description String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  @@map("hot_deals")
}
