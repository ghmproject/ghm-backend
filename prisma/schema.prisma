generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum ListingStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CommunityPostCategory {
  FINDS
  TIPS
  PRICE_CHECKS
}

model User {
  id         Int      @id @default(autoincrement())
  name       String?
  email      String   @unique
  role       Role     @default(USER)
  magicToken String?
  createdAt  DateTime @default(now())

  comments Comment[]
  commentLikes CommentLike[]
   communityPosts CommunityPost[]
   communityPostLikes CommunityPostLike[]
   communityPostComments CommunityPostComment[]
  @@map("users")
}

model Restaurant {
  id Int @id @default(autoincrement())

  name String

  suburb String

  latitude Float?

  longitude Float?

  image String?

  createdAt DateTime @default(now())

  meals Meal[]

  @@map("restaurants")
}

model Meal {
  id Int @id @default(autoincrement())

  restaurantId Int

  dishName String

  cuisine String?

  price Float

  status ListingStatus @default(PENDING)

  isFeatured Boolean @default(false)

  featuredUntil DateTime?
  
  isHidden Boolean @default(false)

  hiddenAt DateTime?

  createdAt DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  reports Report[]

  votes Vote[]

  comments Comment[]

  // HOT DEAL RELATION
  hotDeals HotDeal[]

  @@map("meals")
}

model Report {
  id Int @id @default(autoincrement())

  mealId Int

  reason String

  createdAt DateTime @default(now())

  meal Meal @relation(fields: [mealId], references: [id])

  @@map("reports")
}

enum VoteType {
  UP
  DOWN
}

model Vote {
  id Int @id @default(autoincrement())

  mealId Int

  meal Meal @relation(fields: [mealId], references: [id])

  voteType VoteType

  deviceId String?

  ipAddress String?

  createdAt DateTime @default(now())

  @@unique([mealId, deviceId])
  @@map("votes")
}

model HotDeal {
  id Int @id @default(autoincrement())

  mealId Int

  meal Meal @relation(fields: [mealId], references: [id])

  startDateTime DateTime

  endDateTime DateTime

  description String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([startDateTime])
  @@index([endDateTime])

  @@map("hot_deals")
}


model CommunityPost {
  id              String   @id @default(uuid())

  userId          Int
  user            User     @relation(fields: [userId], references: [id])

  title           String
  category        CommunityPostCategory
  body            String

  imageUrl        String?

  likesCount      Int      @default(0)
  commentsCount   Int      @default(0)

  createdAt       DateTime @default(now())

  likes           CommunityPostLike[]
  comments        CommunityPostComment[]
  @@map("community_posts")
}


model CommunityPostLike {

  id        String   @id @default(uuid())

  postId    String
  userId    Int

  post      CommunityPost @relation(fields: [postId], references: [id])

  user      User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([postId, userId])

  @@map("community_post_likes")
}

model CommunityPostComment {
  id        String   @id @default(uuid())

  postId    String
  userId    Int
  body      String

  post      CommunityPost @relation(fields: [postId], references: [id])
  user      User          @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@map("community_post_comments")
}

model Comment {

  id Int @id @default(autoincrement())

  mealId Int

  meal Meal @relation( fields: [mealId],references: [id])

  // COMMENT OWNER
  userId Int

  user User @relation(fields: [userId], references: [id] )

  // REPLY SYSTEM
  parentCommentId Int?

  parentComment Comment? @relation("CommentReplies",fields: [parentCommentId],references: [id])

  replies Comment[]@relation("CommentReplies")

  content String

  isHidden Boolean@default(false)

  likes CommentLike[]

  createdAt DateTime @default(now())

  @@map("comments")
}

model CommentLike {

  id Int @id @default(autoincrement())

  commentId Int

  comment Comment @relation( fields: [commentId], references: [id])

  userId Int

  user User @relation(fields: [userId],references: [id])

  createdAt DateTime @default(now())

  @@unique([commentId, userId])

  @@map("comment_likes")
}